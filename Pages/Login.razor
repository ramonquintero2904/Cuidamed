@code {
    private LoginViewModel loginModel = new();
    private bool isSmsStep = false; 
    private bool isSmsOk = false; 
    private string AfiliadoSeleccionado { get; set; } = string.Empty;
    private bool AceptoTerminos { get; set; } = false;
    private string errorMessage = string.Empty; // Para renderizar errores en la UI

    // Lista dinámica para rellenar el select de afiliados tras la validación exitosa
    private List<BeneficiarioDto> listaAfiliados = new();

    // Variables para el temporizador
    private System.Threading.Timer? countdownTimer;
    private int timeLeft = 120;

    private BeneficiarioDto? afiliadoDetalle;

    // Propiedad intermedia para capturar el cambio del select
    private string _afiliadoSeleccionado = string.Empty;
    private string AfiliadoSeleccionadoValue
    {
        get => _afiliadoSeleccionado;
        set => _afiliadoSeleccionado = value;
    }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var authState = await AuthState;
            var user = authState.User;

            if (user.Identity != null && user.Identity.IsAuthenticated)
            {
                Navigation.NavigateTo("Home");
            }
        }
    }

    private async Task HandleSubmit()
    {
        errorMessage = string.Empty;

        if (!isSmsStep)
        {
            // --- PASO 1: VALIDAR CÉDULA VÍA API CUIDANET ---
            if (loginModel.Cedula.HasValue && loginModel.Cedula > 0)
            {
                try
                {
                    // Consumimos el Endpoint 3 filtrando por la cédula ingresada
                    var resultado = await CuidanetService.GetBeneficiariosAsync(cedula: loginModel.Cedula.ToString());

                    if (resultado != null && resultado.Any())
                    {
                        // Guardamos temporalmente el primer registro para conocer los datos del grupo familiar
                        var infoUsuario = resultado.First();

                        // OPCIONAL: Aquí disparas el flujo de envío de SMS de tu propio Backend
                        // pasándole los datos o el ID recuperado de CuidaNet.

                        isSmsStep = false;  /* cambiarlo a true*/

                        isSmsOk = true;     /* borrar ---INICIO */
                        try
                        {
                            // --- PASO 3: CARGAR GRUPO FAMILIAR (AFILIADOS) ---
                            // Volvemos a consultar la API pero esta vez para traer a TODOS los beneficiarios
                            // vinculados a la cédula consultada inicialmente.
                            var busquedaInicial = await CuidanetService.GetBeneficiariosAsync(cedula: loginModel.Cedula.ToString());
                            if (busquedaInicial.Any())
                            {
                                int titularId = busquedaInicial.First().TitularId;

                                // Traemos todos los afiliados bajo ese titularId (Endpoint 3 - AND filter)
                                listaAfiliados = await CuidanetService.GetBeneficiariosAsync(titularId: titularId);
                            }

                            isSmsOk = true;
                        }
                        catch (Exception ex)
                        {
                            errorMessage = $"Error al recuperar el grupo familiar: {ex.Message}";
                        }
                        /* borrar ---FIN*/


                        //StartCountdown();
                    }
                    else
                    {
                        errorMessage = "La cédula ingresada no se encuentra registrada en el sistema de CuidaNet.";
                    }
                }
                catch (Exception ex)
                {
                    errorMessage = $"Error de comunicación con la API: {ex.Message}";
                }
            }
        }
        else
        {
            // --- PASO 2: VERIFICAR CÓDIGO SMS ---
            if (loginModel.CodigoSms.HasValue && loginModel.CodigoSms > 0) 
            {
                bool isSmsValid = true; // TODO: Cambiar por tu validación real de SMS de Backend

                if (isSmsValid)
                {
                    //StopTimer();

                    try
                    {
                        // --- PASO 3: CARGAR GRUPO FAMILIAR (AFILIADOS) ---
                        // Volvemos a consultar la API pero esta vez para traer a TODOS los beneficiarios
                        // vinculados a la cédula consultada inicialmente.
                        var busquedaInicial = await CuidanetService.GetBeneficiariosAsync(cedula: loginModel.Cedula.ToString());
                        if (busquedaInicial.Any())
                        {
                            int titularId = busquedaInicial.First().TitularId;

                            // Traemos todos los afiliados bajo ese titularId (Endpoint 3 - AND filter)
                            listaAfiliados = await CuidanetService.GetBeneficiariosAsync(titularId: titularId);
                        }

                        isSmsOk = true;
                    }
                    catch (Exception ex)
                    {
                        errorMessage = $"Error al recuperar el grupo familiar: {ex.Message}";
                    }
                }
                else
                {
                    errorMessage = "El código SMS introducido es incorrecto o ha expirado.";
                }
            }
        }
    }

    private void StartCountdown()
    {
        timeLeft = 120;
        countdownTimer = new System.Threading.Timer(async _ =>
        {
            if (timeLeft > 0)
            {
                timeLeft--;
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                await ResetForm();
            }
        }, null, 0, 1000);
    }

    private async Task ResetForm()
    {
        StopTimer();
        isSmsStep = false;
        loginModel.CodigoSms = null;
        loginModel.Cedula = null;
        listaAfiliados.Clear();
        errorMessage = string.Empty;

        await InvokeAsync(StateHasChanged);
    }

    private void StopTimer()
    {
        countdownTimer?.Dispose();
        countdownTimer = null;
    }

    private string FormatTime(int seconds)
    {
        int minutes = seconds / 60;
        int remainingSeconds = seconds % 60;
        return $"{minutes:D2}:{remainingSeconds:D2}";
    }

    public void Dispose()
    {
        StopTimer();
    }

    private async Task OnAfiliadoCambiado()
    {
        if (int.TryParse(_afiliadoSeleccionado, out int beneficiarioId))
        {
            try
            {
                // Consumimos el Endpoint 4 que ya tienes preparado con la foto en Base64
                afiliadoDetalle = await CuidanetService.GetBeneficiarioDetalleAsync(beneficiarioId);
            }
            catch (Exception)
            {
                afiliadoDetalle = null; // Control de fallos silencioso para la UI
            }
        }
    }

    public class LoginViewModel
    {
        public long? Cedula { get; set; }
        public long? CodigoSms { get; set; }
    }

    private async Task NavigateTo(string page)
    {
        if (string.IsNullOrEmpty(AfiliadoSeleccionadoValue))
            return;

        var customAuth = (CustomAuthStateProvider)AuthStateProvider;

        // Marcamos la autenticación pasando el Id del afiliado seleccionado o la cédula
        long temp = loginModel.Cedula is null ? 0 : Convert.ToInt64(loginModel.Cedula);
        await customAuth.MarkUserAsAuthenticated(temp);

        Navigation.NavigateTo($"{page}");
    }
}